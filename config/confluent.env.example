# Confluent Cloud Kafka
KAFKA_BOOTSTRAP_SERVERS=pkc-XXXXX.eu-west-1.aws.confluent.cloud:9092
KAFKA_API_KEY=your-api-key
KAFKA_API_SECRET=your-api-secret
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN

# Topics
KAFKA_TOPIC_RAW=cpv-raw
KAFKA_TOPIC_HARDCODED=cpv-hardcoded
KAFKA_TOPIC_SPARKML=cpv-sparkml
KAFKA_TOPIC_ONNX=cpv-onnx
KAFKA_TOPIC_SOLVER=cpv-solver
KAFKA_TOPIC_LANGCHAIN=cpv-langchain
KAFKA_TOPIC_N8N=cpv-n8n
KAFKA_TOPIC_MCP=cpv-mcp

# Consumer groups
KAFKA_GROUP_HARDCODED=spendlabel-hardcoded
KAFKA_GROUP_SPARKML=spendlabel-sparkml
KAFKA_GROUP_ONNX=spendlabel-onnx
KAFKA_GROUP_SOLVER=spendlabel-solver
KAFKA_GROUP_LANGCHAIN=spendlabel-langchain
KAFKA_GROUP_N8N=spendlabel-n8n
KAFKA_GROUP_MCP=spendlabel-mcp

# PyFlink
FLINK_CHECKPOINTING_INTERVAL_MS=60000

# PostgreSQL (consumers + ui-chart services)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=spendlabel
POSTGRES_USER=spendlabel
POSTGRES_PASSWORD=spendlabel